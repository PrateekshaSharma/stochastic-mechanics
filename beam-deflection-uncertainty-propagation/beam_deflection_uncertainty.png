import numpy as np
import matplotlib.pyplot as plt

samples = 100000
np.random.seed(42)

span = 5.0
inertia = 2.5e-4

load_mean = 50.0
load_std = 7.5

elasticity_mean = 200.0
elasticity_std = 10.0

load = np.random.normal(load_mean, load_std, samples) * 1e3
elasticity = np.random.normal(elasticity_mean, elasticity_std, samples) * 1e9

deflection = (load * span**3) / (48 * elasticity * inertia) * 1000

deflection_deterministic = (load_mean * 1e3 * span**3) / (48 * elasticity_mean * 1e9 * inertia) * 1000

print(f"Deterministic deflection : {deflection_deterministic:.4f} mm")
print(f"Mean deflection          : {np.mean(deflection):.4f} mm")
print(f"Standard deviation       : {np.std(deflection):.4f} mm")
print(f"95th percentile          : {np.percentile(deflection, 95):.4f} mm")
print(f"99th percentile          : {np.percentile(deflection, 99):.4f} mm")

fig, axes = plt.subplots(1, 3, figsize=(15, 5))

axes[0].hist(load/1e3, bins=80, color='steelblue', alpha=0.7, edgecolor='white')
axes[0].axvline(load_mean, color='navy', linestyle='--', linewidth=2, label=f'Mean = {load_mean} kN')
axes[0].set_xlabel('Load P [kN]')
axes[0].set_ylabel('Frequency')
axes[0].set_title('Input: Load Distribution')
axes[0].legend()
axes[0].grid(True, alpha=0.3)

axes[1].hist(elasticity/1e9, bins=80, color='darkorange', alpha=0.7, edgecolor='white')
axes[1].axvline(elasticity_mean, color='saddlebrown', linestyle='--', linewidth=2, label=f'Mean = {elasticity_mean} GPa')
axes[1].set_xlabel('Elastic Modulus E [GPa]')
axes[1].set_ylabel('Frequency')
axes[1].set_title('Input: Elastic Modulus Distribution')
axes[1].legend()
axes[1].grid(True, alpha=0.3)

axes[2].hist(deflection, bins=80, color='seagreen', alpha=0.7, edgecolor='white')
axes[2].axvline(deflection_deterministic, color='darkgreen', linestyle='--', linewidth=2,
                label=f'Deterministic = {deflection_deterministic:.3f} mm')
axes[2].axvline(np.percentile(deflection, 95), color='red', linestyle=':', linewidth=2,
                label=f'95th percentile = {np.percentile(deflection, 95):.3f} mm')
axes[2].set_xlabel('Mid-span Deflection [mm]')
axes[2].set_ylabel('Frequency')
axes[2].set_title('Output: Deflection Distribution')
axes[2].legend()
axes[2].grid(True, alpha=0.3)

plt.suptitle('Uncertainty Propagation in Beam Deflection', fontsize=13, fontweight='bold')
plt.tight_layout()
plt.savefig('beam_deflection_uncertainty.png', dpi=150, bbox_inches='tight')
plt.show()
